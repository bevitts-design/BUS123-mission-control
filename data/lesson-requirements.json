{
  "version": "0.1",
  "readyToTeach": {
    "studentRequired": ["websiteEntry", "primaryMaterial"],
    "instructorRequired": ["instructorNotes"],
    "answerKeyRequiredWhen": ["workbook", "homeworkProject", "interactive"]
  },
  "trackDefaults": {
    "intro": {
      "slides": "recommended",
      "reading": "optional",
      "workbook": "optional",
      "interactive": "optional"
    },
    "math": {
      "slides": "required",
      "reading": "required",
      "workbook": "required",
      "interactive": "optional"
    },
    "excel": {
      "slides": "required",
      "reading": "required",
      "workbook": "required",
      "interactive": "optional"
    },
    "capstone": {
      "slides": "optional",
      "reading": "optional",
      "workbook": "required",
      "homeworkProject": "required",
      "interactive": "optional"
    }
  },
  "privateFilePatterns": {
    "instructorNotes": [
      "{LESSON_ID}-instructor-notes.md",
      "{LESSON_ID}-instructor-notes.docx",
      "{LESSON_ID}-teaching-guide.md",
      "{LESSON_ID}-teaching-guide.docx"
    ],
    "answerKey": [
      "{LESSON_ID}-answer-key.xlsx",
      "{LESSON_ID}-answer-key.docx",
      "{LESSON_ID}-completed.xlsx",
      "{LESSON_ID}-solutions.xlsx"
    ]
  }
}
